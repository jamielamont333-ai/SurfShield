{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/:slug.:ext", "destination": "/public/:slug.:ext" },
    { "source": "/:slug", "destination": "/public/:slug.html" },
    { "source": "/", "destination": "/public/index.html" }
  ],
  "functions": {
    "api/detect.js": {
      "maxDuration": 30
    }
  }
}
